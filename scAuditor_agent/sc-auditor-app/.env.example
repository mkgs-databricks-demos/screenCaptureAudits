# SC Auditor — Local development environment variables
# Copy to .env and fill in values from your Databricks workspace.

# Lakebase (obtain via: databricks postgres list-endpoints {branch-name})
LAKEBASE_ENDPOINT=projects/sc-auditor/branches/production/endpoints/...
PGHOST=
PGPORT=5432
PGDATABASE=databricks_postgres
PGUSER=
PGSSLMODE=require

# SC Auditor SPN (from secret scope)
SC_AUDITOR_CLIENT_ID=
SC_AUDITOR_CLIENT_SECRET=
SC_AUDITOR_WORKSPACE_URL=https://fevm-hls-fde.cloud.databricks.com

# SQL Warehouse (for ai_parse_document and analytics)
DATABRICKS_WAREHOUSE_ID=

# Volume path (for screenshots and reports)
DATABRICKS_VOLUME_FILES=/Volumes/hls_fde_dev/sc_auditor/screenshots
